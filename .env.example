# NexusOSINT -- Environment variable reference (Phase 16+)
# Copy this file to .env and replace placeholders with real values.
# NEVER commit .env to git -- it is in .gitignore.

# -- Thordata residential rotating proxy -----------------------------------------
# Format: http://td-customer-YOUR_USER:YOUR_PASS@t.pr.thordata.net:9999
# Leave unset to disable proxy (Sherlock will use direct DO IP -- may be
# blocked by LinkedIn / Instagram / TikTok).
THORDATA_PROXY_URL=http://td-customer-YOUR_USER:YOUR_PASS@t.pr.thordata.net:9999

# -- Thordata bandwidth budget limits --------------------------------------------
# SOFT threshold = 50% of daily budget -> WARNING log.
# HARD threshold = full daily budget -> HTTP 503 + Retry-After: 86400.
THORDATA_DAILY_BUDGET_MB=1024
THORDATA_PER_SEARCH_CAP_MB=1

# -- Sherlock confidence scoring thresholds (0-100) ------------------------------
# >= CONFIRMED -> state="confirmed" (full card render).
# >= LIKELY    -> state="likely" (muted card + Unverified badge).
# below LIKELY -> state="not_found" (not rendered).
SHERLOCK_CONFIRMED_THRESHOLD=70
SHERLOCK_LIKELY_THRESHOLD=40
